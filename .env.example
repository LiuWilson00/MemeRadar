# 複製為 .env 並填入實際值（.env 已被 .gitignore 排除）

# Claude API（意圖分析 / rerank / 截圖 / 對方梗圖理解）
ANTHROPIC_API_KEY=

# NVIDIA NIM（VLM 標註，免費）：多把 key 逗號分隔，系統會輪流用以分攤速率限制
# 於 build.nvidia.com 各帳號取得 nvapi- 開頭的 key
NVIDIA_API_KEYS=
# 標註用的 vision 模型（預設 qwen/qwen3.5-122b-a10b；Console 可切換）
NVIDIA_VLM_MODEL=qwen/qwen3.5-122b-a10b

# Voyage AI embedding（選用；若用 BGE-M3 自架則留空）
VOYAGE_API_KEY=

# Reddit 官方 API（選用；--client praw 時需要，於 reddit.com/prefs/apps 建立 script app）
# 公開 .json 客戶端（--client public，預設）不需要憑證
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# 後台（admin console）登入：兩者皆填才啟用 basic auth（留空 = 不設防，方便本機開發）
# 前台（手機 client）永遠公開；後台=桌機 Console（上傳/梗圖庫/複核/報表/設定）
ADMIN_USERNAME=
ADMIN_PASSWORD=

# 本機資料目錄（圖檔物件儲存等），預設 ./data
# 註：結構化資料改存 PostgreSQL（見下），此目錄現在只放圖檔（images/）
MEMERADAR_DATA_DIR=./data

# PostgreSQL（libpq 連線字串）。本機開發：docker compose up -d 起 pgvector
# 上 prod 只換這條（如雲端 Postgres，需啟用 pgvector extension）
DATABASE_URL=postgresql://memeradar:memeradar@localhost:5432/memeradar

# 允許跨源呼叫 API 的前端網域（逗號分隔）。本機走 vite proxy＝同源，留空即可；
# 生產（前後端不同網域）填前端網址，如 https://memeradar.zeabur.app
CORS_ORIGINS=

# 公開昂貴端點（/recommend、/tasks）每 IP 每分鐘上限；0 = 不限流。預設 30。
RATE_LIMIT_PER_MIN=30

# 註：前端的 API 位址是「前端服務」的 build 期變數 VITE_API_BASE_URL（不是後端 .env）。
# 本機留空＝走 vite proxy；生產填 API 網址，如 https://memeradar-api.zeabur.app
